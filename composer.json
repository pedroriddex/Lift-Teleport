{
  "name": "lift/teleport",
  "description": "Lift Teleport WordPress migration plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "LiftTeleport\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LiftTeleport\\Tests\\": "tests/phpunit/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  }
}
